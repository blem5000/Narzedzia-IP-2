<Window x:Class="NarzedziaIP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Narzedzia IP"
        Width="889"
        Height="500"
        FontFamily="Segoe UI"
        FontSize="14"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <TabControl x:Name="tabControl1">

            <!-- DHCP TAB -->
            <TabItem x:Name="tabDHCP" Header="Hostname do DHCP">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="500"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hostname input row -->
                    <Grid Grid.Row="0"
                          Grid.Column="0"
                          Margin="0,0,10,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Hostname:"
                                   Grid.Column="0"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <TextBox x:Name="txtHostname"
                                 Grid.Column="1"
                                 Height="31"
                                 MinWidth="200"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,10,0"/>

                        <Button x:Name="btnSearchConnect"
                                Grid.Column="2"
                                Content="Wyszukaj i połącz"
                                Width="165"
                                Height="40"
                                Click="btnSearchConnect_Click"/>
                    </Grid>

                    <!-- DHCP search status / progress -->
                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Orientation="Vertical"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="txtStatus"
                                   Text=""
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"/>

                        <ProgressBar x:Name="progressSearch"
                                     Height="18"
                                     Width="160"
                                     IsIndeterminate="True"
                                     Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Buttons row -->
                    <WrapPanel Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,20,0,20"
                               Orientation="Horizontal">

                        <Button x:Name="btnSearch"
                                Content="Szukaj"
                                Width="92"
                                Height="40"
                                Margin="0,0,10,10"
                                Click="btnSearch_Click"/>

                        <Button x:Name="btnClear"
                                Content="Wyczyść"
                                Width="92"
                                Height="40"
                                Margin="0,0,10,10"
                                Click="btnClear_Click"/>

                        <Button x:Name="btnCopyIP"
                                Content="Kopiuj IP"
                                Width="92"
                                Height="40"
                                Margin="0,0,10,10"
                                Click="btnCopyIP_Click"/>

                        <Button x:Name="btnCopyMAC"
                                Content="Kopiuj MAC"
                                Width="105"
                                Height="40"
                                Margin="0,0,10,10"
                                Click="btnCopyMAC_Click"/>

                        <Button x:Name="btnMSRA"
                                Content="MSRA"
                                Width="92"
                                Height="40"
                                Margin="0,0,10,10"
                                Click="btnMSRA_Click"/>

                    </WrapPanel>

                    <!-- Result box -->
                    <GroupBox Grid.Row="2"
                              Grid.Column="0"
                              Header="Wynik DHCP"
                              Width="481"
                              Margin="0,0,15,0"
                              HorizontalAlignment="Left">

                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="IP:"
                                       FontWeight="Bold"
                                       Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,15,10"/>

                            <TextBlock x:Name="lblIP"
                                       Text=""
                                       Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="0,0,0,10"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="MAC:"
                                       FontWeight="Bold"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"/>

                            <TextBlock x:Name="lblMAC"
                                       Text=""
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </GroupBox>

                    <!-- History -->
                    <GroupBox Grid.Row="0"
                              Grid.RowSpan="3"
                              Grid.Column="1"
                              Header="Historia"
                              Margin="10,90,0,0">

                        <TextBox x:Name="rtbHistoria"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- PING TAB -->
            <TabItem x:Name="tabPing" Header="Ping">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="500"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ping hostname row -->
                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">

                        <TextBlock Text="Hostname:"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <TextBox x:Name="txtHostname2"
                                 Width="220"
                                 Height="31"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <GroupBox Grid.Row="0"
                    Grid.Column="1"
                    Header="Dźwięk"
                    Margin="10,0,0,10">

                        <StackPanel Margin="10">

                            <RadioButton x:Name="rbtnSoundOff"
                     Content="Bez dźwięku"
                     IsChecked="True"
                     Margin="0,0,0,6"/>

                            <RadioButton x:Name="rbtnSoundSuccess"
                     Content="Dźwięk przy sukcesie"
                     Margin="0,0,0,6"/>

                            <RadioButton x:Name="rbtnSoundFail"
                     Content="Dźwięk przy błędzie"/>

                        </StackPanel>
                    </GroupBox>

                    <!-- Ping buttons -->
                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                Margin="0,20,0,20">

                        <Button x:Name="btnStartPing"
                                Content="Start"
                                Width="83"
                                Height="32"
                                Margin="0,0,10,0"
                                Click="btnStartPing_Click"/>

                        <Button x:Name="btnStopPing"
                                Content="Stop"
                                Width="83"
                                Height="32"
                                Click="btnStopPing_Click"/>
                    </StackPanel>

                    <!-- Ping status / progress -->
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Orientation="Vertical"
                                Margin="10,20,0,20"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="txtPingStatus"
                                   Text=""
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"/>

                        <ProgressBar x:Name="progressPing"
                                     Width="160"
                                     Height="18"
                                     IsIndeterminate="True"
                                     Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Ping output -->
                    <GroupBox Grid.Row="2"
                              Grid.Column="0"
                              Grid.ColumnSpan="2"
                              Header="Ping">

                        <TextBox x:Name="rtbPing"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"/>
                    </GroupBox>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>