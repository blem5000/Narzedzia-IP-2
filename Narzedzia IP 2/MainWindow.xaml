<Window x:Class="NarzedziaIP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Narzedzia IP"
        Width="889"
        Height="500"
        FontFamily="Segoe UI"
        FontSize="14"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <TabControl x:Name="tabControl1">

            <!-- DHCP TAB -->
            <TabItem x:Name="tabDHCP" Header="Hostname do DHCP">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="500"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hostname input row -->
                    <Grid Grid.Row="0"
                          Grid.Column="0"
                          Margin="0,0,10,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Hostname:"
                                   Grid.Column="0"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <TextBox x:Name="txtHostname"
                                 Grid.Column="1"
                                 Height="31"
                                 MinWidth="200"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,10,0"/>

                        <Button x:Name="btnSearchConnect"
                                Grid.Column="2"
                                Content="Wyszukaj i połącz"
                                Width="165"
                                Height="40"
                                Click="btnSearchConnect_Click"/>
                    </Grid>

                    <!-- DHCP search status / progress -->
                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Orientation="Vertical"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="txtStatus"
                                   Text=""
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"/>

                        <ProgressBar x:Name="progressSearch"
                                     Height="18"
                                     Width="160"
                                     IsIndeterminate="True"
                                     Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Buttons row -->
                    <WrapPanel Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,20,0,20"
                               Orientation="Horizontal">

                        <Button x:Name="btnSearch"
                                Content="Szukaj"
                                Width="92"
                                Height="40"
                                Margin="0,0,10,10"
                                Click="btnSearch_Click"/>

                        <Button x:Name="btnClear"
                                Content="Wyczyść"
                                Width="92"
                                Height="40"
                                Margin="0,0,10,10"
                                Click="btnClear_Click"/>

                        <Button x:Name="btnCopyIP"
                                Content="Kopiuj IP"
                                Width="92"
                                Height="40"
                                Margin="0,0,10,10"
                                Click="btnCopyIP_Click"/>

                        <Button x:Name="btnCopyMAC"
                                Content="Kopiuj MAC"
                                Width="105"
                                Height="40"
                                Margin="0,0,10,10"
                                Click="btnCopyMAC_Click"/>

                        <Button x:Name="btnMSRA"
                                Content="MSRA"
                                Width="92"
                                Height="40"
                                Margin="0,0,10,10"
                                Click="btnMSRA_Click"/>

                    </WrapPanel>

                    <!-- Result box -->
                    <GroupBox Grid.Row="2"
                              Grid.Column="0"
                              Header="Wynik DHCP"
                              Width="481"
                              Margin="0,0,15,0"
                              HorizontalAlignment="Left">

                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="IP:"
               FontWeight="Bold"
               Grid.Row="0"
               Grid.Column="0"
               Margin="0,0,15,10"/>

                            <TextBlock x:Name="lblIP"
               Text=""
               Grid.Row="0"
               Grid.Column="1"
               Margin="0,0,0,10"
               TextWrapping="Wrap"/>

                            <TextBlock Text="MAC:"
               FontWeight="Bold"
               Grid.Row="1"
               Grid.Column="0"
               Margin="0,0,15,10"/>

                            <TextBlock x:Name="lblMAC"
               Text=""
               Grid.Row="1"
               Grid.Column="1"
               Margin="0,0,0,10"
               TextWrapping="Wrap"/>

                            <TextBlock x:Name="lblDnsWarning"
               Grid.Row="2"
               Grid.Column="0"
               Grid.ColumnSpan="2"
               Text=""
               Foreground="DarkOrange"
               FontWeight="Bold"
               TextWrapping="Wrap"
               Visibility="Collapsed"/>
                        </Grid>
                    </GroupBox>

                    <!-- History -->
                    <GroupBox Grid.Row="0"
                              Grid.RowSpan="3"
                              Grid.Column="1"
                              Header="Historia"
                              Margin="10,90,0,0">

                        <TextBox x:Name="rtbHistoria"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- PING TAB -->
            <TabItem x:Name="tabPing" Header="Ping">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="500"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ping hostname row -->
                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">

                        <TextBlock Text="Hostname:"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <TextBox x:Name="txtHostname2"
                                 Width="220"
                                 Height="31"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <GroupBox Grid.Row="0"
                    Grid.Column="1"
                    Header="Dźwięk"
                    Margin="10,0,0,10">

                        <StackPanel Margin="10">

                            <RadioButton x:Name="rbtnSoundOff"
                     Content="Bez dźwięku"
                     IsChecked="True"
                     Margin="0,0,0,6"/>

                            <RadioButton x:Name="rbtnSoundSuccess"
                     Content="Dźwięk przy sukcesie"
                     Margin="0,0,0,6"/>

                            <RadioButton x:Name="rbtnSoundFail"
                     Content="Dźwięk przy błędzie"/>

                        </StackPanel>
                    </GroupBox>

                    <!-- Ping buttons -->
                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                Margin="0,20,0,20">

                        <Button x:Name="btnStartPing"
                                Content="Start"
                                Width="83"
                                Height="32"
                                Margin="0,0,10,0"
                                Click="btnStartPing_Click"/>

                        <Button x:Name="btnStopPing"
                                Content="Stop"
                                Width="83"
                                Height="32"
                                Click="btnStopPing_Click"/>
                    </StackPanel>

                    <!-- Ping status / progress -->
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Orientation="Vertical"
                                Margin="10,20,0,20"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="txtPingStatus"
                                   Text=""
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"/>

                        <ProgressBar x:Name="progressPing"
                                     Width="160"
                                     Height="18"
                                     IsIndeterminate="True"
                                     Visibility="Collapsed"/>
                    </StackPanel>

                  
                    <!-- Ping output -->
                    <GroupBox Grid.Row="2"
                              Grid.Column="0"
                              Grid.ColumnSpan="2"
                              Header="Ping">

                        <TextBox x:Name="rtbPing"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"/>
                    </GroupBox>
                </Grid>
            </TabItem>
            <!-- ACL TAB -->
            <TabItem x:Name="tabACL" Header="ACL">
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <!-- SOURCE -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="IP źródłowe:"
               FontWeight="Bold"
               VerticalAlignment="Center"/>

                        <TextBlock x:Name="lblDhcpStatus"
               Grid.Column="1"
               Margin="10,0,0,0"
               FontWeight="Bold"
               VerticalAlignment="Center"/>
                    </Grid>

                    <TextBox x:Name="txtAclSource"
                 Grid.Row="1"
                 Height="30"
                 Margin="0,5,0,10"/>

                    <!-- DEST LIST -->
                    <TextBlock Text="Lista IP (ENTER / przecinki):"
                   Grid.Row="2"
                   FontWeight="Bold"/>

                    <TextBox x:Name="txtAclDest"
                 Grid.Row="3"
                 Height="120"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 Margin="0,5,0,10"/>

                    <!-- BUTTON -->
                    <StackPanel Grid.Row="4"
            Orientation="Horizontal"
            Margin="0,5,0,0">

                        <Button x:Name="btnGenerateAcl"
            Content="Generuj ACL"
            Width="160"
            Height="35"
            Margin="0,0,10,0"
            Click="BtnGenerateAcl_Click"/>

                        <Button x:Name="btnCopyAcl"
            Content="Kopiuj do schowka"
            Width="180"
            Height="35"
            Click="BtnCopyAcl_Click"/>

                    </StackPanel>

                    <TextBlock Text="Output Cisco:"
                Grid.Row="5"
                FontWeight="Bold"/>
                    

                    <!-- OUTPUT -->
                    <TextBox x:Name="txtAclOutput"
                 Grid.Row="6"
                 Margin="0,10,0,0"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 IsReadOnly="True"/>

                </Grid>
            </TabItem>

            <TabItem x:Name="tabHelp" Header="Instrukcja">
                <Grid Margin="10">
                    <RichTextBox x:Name="rtbManual"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Segoe UI"
                     FontSize="14"
                     Padding="10"
                     BorderThickness="1">

                        <FlowDocument>

                            <Paragraph FontSize="20" FontWeight="Bold">
                                Narzędzia IP - instrukcja obsługi
                            </Paragraph>

                            <Paragraph>
                                Program służy do wyszukiwania adresów IP komputerów w DHCP, porównywania wyniku z DNS,
                    kopiowania adresów IP/MAC, uruchamiania Pomocy zdalnej MSRA oraz wykonywania cyklicznego pingowania.
                            </Paragraph>

                            <Paragraph FontSize="16" FontWeight="Bold">
                                1. Uruchomienie programu i wybór serwera DHCP
                            </Paragraph>

                            <Paragraph>
                                Po uruchomieniu program automatycznie sprawdza domyślny serwer DHCP:
                                <Bold>150.150.222.20</Bold> .
                            </Paragraph>

                            <List>
                                <ListItem>
                                    <Paragraph>
                                        Jeśli domyślny serwer DHCP odpowiada poprawnie, program automatycznie przechodzi do głównego okna.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        Jeśli domyślny serwer DHCP nie odpowiada albo nie można pobrać zakresów DHCP,
                            użytkownik może wpisać inny adres IP serwera DHCP.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        Podany ręcznie adres DHCP jest sprawdzany po kliknięciu przycisku
                                        <Bold>OK</Bold> .
                                    </Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph FontSize="16" FontWeight="Bold">
                                2. Zakładka: Hostname do DHCP
                            </Paragraph>

                            <Paragraph>
                                <Bold>Pole Hostname:</Bold>
                                W tym polu można wpisać nazwę komputera albo bezpośrednio adres IP.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Przycisk Wyszukaj i połącz:</Bold>
                            </Paragraph>

                            <List>
                                <ListItem>
                                    <Paragraph>
                                        Jeśli wpisano
                                        <Bold>hostname</Bold> , program wyszukuje komputer w DHCP,
                            pobiera aktywny adres IP i MAC, a następnie uruchamia Pomoc zdalną MSRA.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        Jeśli wpisano
                                        <Bold>adres IP</Bold> , program nie odpytuje DHCP i od razu uruchamia MSRA dla tego adresu.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        Naciśnięcie klawisza
                                        <Bold>Enter</Bold> w polu Hostname działa tak samo jak przycisk
                                        <Bold>Wyszukaj i połącz</Bold> .
                                    </Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph>
                                <Bold>Przycisk Szukaj:</Bold>
                            </Paragraph>

                            <List>
                                <ListItem>
                                    <Paragraph>
                                        Jeśli wpisano
                                        <Bold>hostname</Bold> , program wyszukuje adres IP i MAC w DHCP.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        Jeśli wpisano
                                        <Bold>adres IP</Bold> , program nie wykonuje wyszukiwania w DHCP,
                            tylko przyjmuje wpisany adres jako aktualny wynik.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        Podczas wyszukiwania wyświetlany jest pasek postępu oraz komunikat
                                        <Bold>Szukam w DHCP...</Bold> .
                                    </Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph>
                                <Bold>Wynik DHCP:</Bold>
                                W tym miejscu wyświetlany jest znaleziony adres IP oraz adres MAC.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Porównanie DNS z DHCP:</Bold>
                                Po znalezieniu aktywnego adresu IP w DHCP program sprawdza również adres IP zwracany przez DNS.
                    Jeśli adres IP w DNS jest inny niż adres IP znaleziony w DHCP, pod wynikiem pojawi się ostrzeżenie:
                                <Italic>IP w DNS jest inny niż w DHCP</Italic> , razem z adresem IP z DNS.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Przycisk Kopiuj IP:</Bold>
                                Kopiuje znaleziony albo wpisany adres IP do schowka.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Przycisk Kopiuj MAC:</Bold>
                                Kopiuje znaleziony adres MAC do schowka. Myślniki w adresie MAC są usuwane.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Przycisk MSRA:</Bold>
                                Uruchamia Pomoc zdalną Microsoft Remote Assistance dla aktualnie wyświetlonego adresu IP.
                            </Paragraph>

                            <List>
                                <ListItem>
                                    <Paragraph>
                                        Jeśli znaleziono więcej niż jeden aktywny adres IP, MSRA nie uruchamia się automatycznie.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        Jeśli aktualna wartość IP nie jest poprawnym adresem IPv4, program wyświetli ostrzeżenie.
                                    </Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph>
                                <Bold>Przycisk Wyczyść:</Bold>
                                Czyści pole Hostname, wynik IP/MAC oraz komunikat ostrzegawczy DNS/DHCP.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Historia:</Bold>
                                Pokazuje wykonane wyszukiwania wraz z datą i godziną.
                    Historia może również zawierać informacje o różnicy między DNS i DHCP.
                            </Paragraph>

                            <Paragraph FontSize="16" FontWeight="Bold">
                                3. Zakładka: Ping
                            </Paragraph>

                            <Paragraph>
                                <Bold>Pole Hostname:</Bold>
                                Można wpisać nazwę komputera albo bezpośrednio adres IP.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Przycisk Start:</Bold>
                            </Paragraph>

                            <List>
                                <ListItem>
                                    <Paragraph>
                                        Jeśli wpisano
                                        <Bold>hostname</Bold> , program najpierw wyszukuje aktywny adres IP w DHCP,
                            a następnie rozpoczyna cykliczne pingowanie.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        Jeśli wpisano
                                        <Bold>adres IP</Bold> , program pomija wyszukiwanie w DHCP
                            i od razu rozpoczyna pingowanie tego adresu.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        Podczas wyszukiwania hosta w DHCP wyświetlany jest pasek postępu oraz komunikat
                                        <Bold>Szukam hosta w DHCP...</Bold> .
                                    </Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph>
                                <Bold>Przycisk Stop:</Bold>
                                Zatrzymuje cykliczne pingowanie.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Opcje dźwięku:</Bold>
                            </Paragraph>

                            <List>
                                <ListItem>
                                    <Paragraph>
                                        <Bold>Bez dźwięku</Bold> - ping działa bez powiadomień dźwiękowych.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        <Bold>Dźwięk przy sukcesie</Bold> - program odtwarza dźwięk po udanym pingu.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        <Bold>Dźwięk przy błędzie</Bold> - program odtwarza dźwięk, gdy ping się nie powiedzie.
                                    </Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph FontSize="16" FontWeight="Bold">
                                4. Wymagania techniczne
                            </Paragraph>

                            <Paragraph>
                                Program korzysta z poleceń PowerShell DHCP:
                            </Paragraph>

                            <List>
                                <ListItem>
                                    <Paragraph>
                                        <Bold>Get-DhcpServerv4Scope</Bold>
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        <Bold>Get-DhcpServerv4Lease</Bold>
                                    </Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph>
                                Na komputerze musi być dostępny moduł DHCP / RSAT.
                    Użytkownik musi mieć uprawnienia do odpytywania serwera DHCP.
                            </Paragraph>

                            <Paragraph>
                                Funkcja MSRA wymaga dostępności narzędzia Microsoft Remote Assistance
                                <Bold>msra.exe</Bold> na komputerze, z którego uruchamiany jest program.
                            </Paragraph>

                            <Paragraph FontSize="16" FontWeight="Bold">
                                5. Typowe komunikaty
                            </Paragraph>

                            <Paragraph>
                                <Bold>Brak hostname!</Bold>
                                Nie wpisano nazwy hosta ani adresu IP.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Brak adresu IP w DHCP</Bold>
                                Nie znaleziono wpisu DHCP dla podanej nazwy.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Nie znaleziono aktywnego IP</Bold>
                                Adres istnieje w DHCP, ale nie odpowiada na ping.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Błąd DHCP</Bold>
                                Wystąpił problem z odpytaniem serwera DHCP, uprawnieniami albo modułem RSAT.
                            </Paragraph>

                            <Paragraph>
                                <Bold>IP w DNS jest inny niż w DHCP</Bold>
                                DNS zwraca inny adres IP niż aktywny adres znaleziony w DHCP.
                    W komunikacie wyświetlany jest adres IP zwrócony przez DNS.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Znaleziono więcej niż jeden adres IP</Bold>
                                Dla podanego hostname znaleziono więcej niż jeden aktywny adres IP.
                    W takim przypadku MSRA nie uruchamia się automatycznie.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Aktualna wartość IP nie wygląda jak poprawny adres IPv4</Bold>
                                Program nie uruchomi MSRA, ponieważ wynik nie jest pojedynczym poprawnym adresem IPv4.
                            </Paragraph>
                            <Paragraph FontSize="16" FontWeight="Bold">
                                6. Zakładka: ACL
                            </Paragraph>

                            <Paragraph>
                                Zakładka ACL służy do generowania list dostępu (ACL) dla urządzeń Cisco na podstawie podanych adresów IP.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Pole IP źródłowe:</Bold>
                                W tym polu należy wpisać adres IP hosta, dla którego ma zostać wygenerowana reguła ACL.
                            </Paragraph>

                            <Paragraph>
                                Program automatycznie sprawdza, czy podany adres posiada rezerwację w DHCP.
    Wynik wyświetlany jest obok pola:
                            </Paragraph>

                            <List>
                                <ListItem>
                                    <Paragraph>
                                        <Bold>✅ Rezerwacja DHCP OK</Bold> – adres posiada rezerwację.
                                    </Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>
                                        <Bold>❌ Brak rezerwacji DHCP</Bold> – adres nie posiada rezerwacji.
                                    </Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph>
                                Podczas sprawdzania wyświetlany jest status:
                                <Italic>⏳ Sprawdzanie DHCP...</Italic> .
                            </Paragraph>

                            <Paragraph>
                                Brak rezerwacji nie blokuje działania – program wygeneruje ACL mimo ostrzeżenia.
                            </Paragraph>

                            <Paragraph>
                                <Bold>Pole Lista IP:</Bold>
                                W tym polu należy wpisać adresy docelowe (ENTER lub przecinki).
                            </Paragraph>

                            <Paragraph>
                                Program automatycznie:
                            </Paragraph>

                            <List>
                                <ListItem>
                                    <Paragraph>dzieli adresy na odpowiednie podsieci,</Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>łączy je w zakresy (wildcard),</Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>generuje reguły ACL IN oraz OUT,</Paragraph>
                                </ListItem>
                                <ListItem>
                                    <Paragraph>pomija numery sekwencji podzielne przez 10.</Paragraph>
                                </ListItem>
                            </List>

                            <Paragraph>
                                <Bold>Przycisk Generuj ACL:</Bold>
                                generuje pełną konfigurację Cisco (conf t, ACL, resequence, zapis).
                            </Paragraph>

                            <Paragraph>
                                <Bold>Przycisk Kopiuj do schowka:</Bold>
